<svg xmlns="http://www.w3.org/2000/svg" width="1080" height="1920" viewBox="0 0 1080 1920">
  <rect width="1080" height="1920" fill="#010101"/>
  <rect x="0" y="0" width="1080" height="120" fill="rgba(15,15,25,0.95)"/>
  <text x="60" y="75" font-family="Arial" font-size="28" font-weight="bold" fill="#ec4899">📊 Quiniela IA</text>
  <text x="540" y="250" font-family="Arial" font-size="48" font-weight="bold" fill="#ffffff" text-anchor="middle">Quiniela IA</text>
  <text x="540" y="320" font-family="Arial" font-size="24" fill="#94a3b8" text-anchor="middle">Análisis estadístico con Machine Learning</text>
  <text x="540" y="450" font-family="Arial" font-size="28" fill="#94a3b8" text-anchor="middle">Elegí el sorteo:</text>
  <rect x="100" y="500" width="200" height="80" rx="20" fill="#ff3366"/>
  <text x="200" y="550" font-family="Arial" font-size="22" font-weight="bold" fill="#ffffff" text-anchor="middle">Previa</text>
  <rect x="340" y="500" width="200" height="80" rx="20" fill="rgba(255,255,255,0.06)"/>
  <text x="440" y="550" font-family="Arial" font-size="22" font-weight="bold" fill="#94a3b8" text-anchor="middle">Primera</text>
  <rect x="580" y="500" width="200" height="80" rx="20" fill="rgba(255,255,255,0.06)"/>
  <text x="680" y="550" font-family="Arial" font-size="22" font-weight="bold" fill="#94a3b8" text-anchor="middle">Matutina</text>
  <rect x="100" y="620" width="200" height="80" rx="20" fill="rgba(255,255,255,0.06)"/>
  <text x="200" y="670" font-family="Arial" font-size="22" font-weight="bold" fill="#94a3b8" text-anchor="middle">Vespertina</text>
  <rect x="340" y="620" width="200" height="80" rx="20" fill="rgba(255,255,255,0.06)"/>
  <text x="440" y="670" font-family="Arial" font-size="22" font-weight="bold" fill="#94a3b8" text-anchor="middle">Nocturna</text>
  <rect x="200" y="780" width="680" height="70" rx="16" fill="linear-gradient(135deg,#ff3366,#cc0033)"/>
  <text x="540" y="825" font-family="Arial" font-size="24" font-weight="bold" fill="#ffffff" text-anchor="middle">⚡ Generar Análisis Ahora</text>
  <text x="540" y="950" font-family="Arial" font-size="32" font-weight="bold" fill="#ffffff" text-anchor="middle">Top 10 números</text>
  <text x="540" y="1000" font-family="Arial" font-size="20" fill="#94a3b8" text-anchor="middle">con mayor frecuencia estadística</text>
  <g transform="translate(100,1060)">
    <rect width="180" height="120" rx="16" fill="rgba(168,85,247,0.12)" stroke="rgba(168,85,247,0.3)"/>
    <text x="90" y="40" font-family="Arial" font-size="16" fill="#94a3b8" text-anchor="middle">#1</text>
    <text x="90" y="80" font-family="Arial" font-size="36" font-weight="bold" fill="#c4b5fd" text-anchor="middle">47</text>
    <text x="90" y="110" font-family="Arial" font-size="14" fill="#a78bfa" text-anchor="middle">89%</text>
  </g>
  <g transform="translate(300,1060)">
    <rect width="180" height="120" rx="16" fill="rgba(168,85,247,0.12)" stroke="rgba(168,85,247,0.3)"/>
    <text x="90" y="40" font-family="Arial" font-size="16" fill="#94a3b8" text-anchor="middle">#2</text>
    <text x="90" y="80" font-family="Arial" font-size="36" font-weight="bold" fill="#c4b5fd" text-anchor="middle">23</text>
    <text x="90" y="110" font-family="Arial" font-size="14" fill="#a78bfa" text-anchor="middle">85%</text>
  </g>
  <g transform="translate(500,1060)">
    <rect width="180" height="120" rx="16" fill="rgba(168,85,247,0.12)" stroke="rgba(168,85,247,0.3)"/>
    <text x="90" y="40" font-family="Arial" font-size="16" fill="#94a3b8" text-anchor="middle">#3</text>
    <text x="90" y="80" font-family="Arial" font-size="36" font-weight="bold" fill="#c4b5fd" text-anchor="middle">71</text>
    <text x="90" y="110" font-family="Arial" font-size="14" fill="#a78bfa" text-anchor="middle">82%</text>
  </g>
  <g transform="translate(700,1060)">
    <rect width="180" height="120" rx="16" fill="rgba(168,85,247,0.12)" stroke="rgba(168,85,247,0.3)"/>
    <text x="90" y="40" font-family="Arial" font-size="16" fill="#94a3b8" text-anchor="middle">#4</text>
    <text x="90" y="80" font-family="Arial" font-size="36" font-weight="bold" fill="#c4b5fd" text-anchor="middle">08</text>
    <text x="90" y="110" font-family="Arial" font-size="14" fill="#a78bfa" text-anchor="middle">79%</text>
  </g>
  <text x="540" y="1350" font-family="Arial" font-size="18" fill="#475569" text-anchor="middle">Motor de 30 factores estadísticos</text>
  <text x="540" y="1400" font-family="Arial" font-size="18" fill="#475569" text-anchor="middle">+ Machine Learning (XGBoost + LightGBM)</text>
  <text x="540" y="1450" font-family="Arial" font-size="18" fill="#475569" text-anchor="middle">Datos oficiales actualizados</text>
  <rect x="0" y="1800" width="1080" height="120" fill="rgba(15,15,25,0.95)"/>
  <text x="540" y="1860" font-family="Arial" font-size="16" fill="#475569" text-anchor="middle">Herramienta de análisis estadístico · No garantiza resultados</text>
</svg>
